# Environment variables for DentFlow WhatsApp Service
PORT=3001

# Secret key shared with Django backend — must match WHATSAPP_SERVICE_SECRET in Django .env
SERVICE_SECRET=change-this-to-a-strong-random-secret

# Optional: Path to Chromium/Chrome executable (leave blank to use Puppeteer's bundled Chromium)
# On Render, set this to: /usr/bin/google-chrome-stable
PUPPETEER_EXECUTABLE_PATH=
